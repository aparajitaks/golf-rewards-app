# =============================================================================
# Local development: copy to this file your real values, then run `npm run dev`
# (dotenv-cli loads .env.example automatically). Do NOT commit real secrets.
# Production (Vercel): set the same variable names in the project Environment UI.
# =============================================================================

# Site (use http://localhost:3000 locally; production must be https)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — webhooks / trusted jobs (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_YEARLY=price_your_yearly_price_id

# Optional rate limiting (Upstash / Cloudflare later)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
